# Server
HIVEMIND_ENV=local                          # local | production
HIVEMIND_HOST=0.0.0.0
HIVEMIND_PORT=8080
HIVEMIND_LOG_LEVEL=INFO

# Storage backend selector. local | gcs
# In local dev, "local" reads/writes the directory at HIVEMIND_LOCAL_CONTENT_ROOT.
# In prod, set to "gcs" and provide HIVEMIND_GCS_BUCKET.
STORAGE_BACKEND=local
HIVEMIND_LOCAL_CONTENT_ROOT=./content
HIVEMIND_GCS_BUCKET=
HIVEMIND_GCS_PREFIX=

# Postgres
# In local dev (docker compose), uses the bundled postgres service.
DATABASE_URL=postgresql+psycopg://hivemind:hivemind@postgres:5432/hivemind

# Auth (Google OAuth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
SESSION_SECRET=change-me-to-a-long-random-string

# Frontend
FRONTEND_ORIGIN=http://localhost:5173
